# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=maxplast_db
DB_PORT=5447
DATABASE_URL=postgresql://postgres:postgres@db:5432/maxplast_db

# API Configuration
API_PORT=8917
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=false
SQL_ECHO=false

# Frontend Configuration
FRONTEND_PORT=3947

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMS Configuration
SMS_ENABLED=false
SMS_PROVIDER=eskiz
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
DIRECTOR_TELEGRAM_IDS=123456789,987654321
BOT_PORT=8923
COMPANY_NAME=Max Plast
COMPANY_PHONE=+998 90 123 45 67

# pgAdmin (optional, for development)
PGADMIN_EMAIL=admin@maxplast.uz
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5393

# Backup service
BACKUP_PORT=8743
BACKUP_API_KEY=erp-backup-secret-2026

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/app/uploads
